# =============================================================================
# Robobrain RED — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. (.env is already in .gitignore)
#
# Usage: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI Models — Claude API
# -----------------------------------------------------------------------------
# Set your Anthropic API key to use Claude models for proposal drafting,
# bid/no-bid analysis, and cost estimation.
# If not set, all Claude-powered features fall back to local Ollama.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection (defaults shown — override to use a different model)
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Local LLM — Ollama (zero-cost fallback)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MODEL_LARGE=llama3.1

# -----------------------------------------------------------------------------
# Application Server
# -----------------------------------------------------------------------------
SERVER_PORT=9090
SERVER_HOST=localhost

# -----------------------------------------------------------------------------
# Database Paths
# -----------------------------------------------------------------------------
PROPOSALS_DB_PATH=opportunities.db
SEARCH_DB_PATH=search_system.db

# -----------------------------------------------------------------------------
# Unanet CRM Integration
# -----------------------------------------------------------------------------
# Get your API key from Unanet Admin → API Management
UNANET_BASE_URL=https://yourcompany.unanet.biz
UNANET_API_KEY=your_unanet_api_key_here
UNANET_COMPANY=yourcompany

# Optional: Override pipeline stage mappings (JSON string)
# UNANET_STAGE_MAPPING={"identified":"1_PROSPECT","qualifying":"2_QUALIFY"}

# Optional: Override field mapping file path
# UNANET_MAPPING_FILE=proposal/integrations/unanet_mapping.json

# -----------------------------------------------------------------------------
# SharePoint / Microsoft Graph API
# -----------------------------------------------------------------------------
# Register an Azure AD app at https://portal.azure.com
# Required permissions: Sites.ReadWrite.All, Files.ReadWrite.All (Delegated)
SHAREPOINT_TENANT_ID=your_azure_ad_tenant_id
SHAREPOINT_CLIENT_ID=your_app_registration_client_id
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/Proposals
SHAREPOINT_DRIVE_NAME=Documents

# Token cache file (auto-created after first authentication)
# SHAREPOINT_TOKEN_CACHE=~/.red/sharepoint_token.json

# -----------------------------------------------------------------------------
# Confluence Integration
# -----------------------------------------------------------------------------
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
CONFLUENCE_SPACE_PREFIX=PROP

# For on-premise Confluence Server/Data Center:
# CONFLUENCE_BASE_URL=https://confluence.yourcompany.com
# CONFLUENCE_USE_PERSONAL_TOKEN=true
# CONFLUENCE_PERSONAL_TOKEN=your_personal_access_token_here

# -----------------------------------------------------------------------------
# Redis (optional — for real-time event streaming)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Proposal Workflow Configuration
# -----------------------------------------------------------------------------
# Company capability keywords for opportunity scoring
COMPANY_NAICS_CODES=541715,541330,541990,519130

# Company name for auto-population in documents
COMPANY_NAME=Your Company LLC
COMPANY_CAGE_CODE=XXXXX
COMPANY_SAM_UEI=XXXXXXXXXXXX
COMPANY_EMAIL_DOMAIN=yourcompany.com

# Proposal team email distribution list
PROPOSAL_TEAM_EMAIL=proposals@yourcompany.com

# Default capture manager (if none assigned)
DEFAULT_CAPTURE_MANAGER=TBD

# Bid/No-Bid score thresholds (0-100 scale)
BID_THRESHOLD=70
CONDITIONAL_THRESHOLD=50

# =============================================================================
# Setup Checklist
# =============================================================================
# 1. Copy to .env:      cp .env.example .env
# 2. Set API keys:      Fill in ANTHROPIC_API_KEY
# 3. Optional CRM:      Fill in UNANET_* vars if using Unanet
# 4. Optional SP:       Fill in SHAREPOINT_* vars, then run:
#                       uv run python -c "from proposal.integrations.sharepoint import SharePointClient; SharePointClient().authenticate()"
# 5. Optional Confluence: Fill in CONFLUENCE_* vars
# 6. Run migration:     uv run python -c "from proposal.database import run_migration; run_migration()"
# =============================================================================
