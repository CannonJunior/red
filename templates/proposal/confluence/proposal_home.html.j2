  <li><a href="./Gold Team">Gold Team Review</a></li>
  <li><a href="./Hotwash">Hotwash &amp; Lessons Learned</a></li>
</ul>

<h2>Status Updates</h2>
<ac:structured-macro ac:name="recently-updated">
  <ac:parameter ac:name="spaces">{{ confluence_space_key }}</ac:parameter>
  <ac:parameter ac:name="max">10</ac:parameter>
</ac:structured-macro>
